<Window
    x:Class="MultiSearchDemoWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="C# WinUI Multi-Thread Sorting Visualizer">

    <Grid Background="Black" Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <Button x:ConnectionId='2' x:Name="StartButton" Content="Start Algorithms Visualization" 
                                          
                Background="#333333" Foreground="White"
                Width="280" Height="40" Margin="0,0,0,12" />

        <Grid x:ConnectionId='3' Grid.Row="1" x:Name="MainGrid" ColumnSpacing="4" RowSpacing="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
        </Grid>
    </Grid>
</Window>

